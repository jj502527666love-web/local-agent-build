{
  "id": "product-table-of-content-slide",
  "name": "目录页",
  "category": "ProductOverview",
  "description": "左侧章节列表(标题/简述) + 右侧标题与描述段落的两栏目录版式。",
  "schema": {
    "title": {
      "type": "text",
      "label": "右侧标题",
      "required": true,
      "maxChars": 18
    },
    "description": {
      "type": "multiline",
      "label": "右侧描述",
      "maxChars": 160
    },
    "sections": {
      "type": "stat-list",
      "label": "章节(标题/简述)",
      "required": true,
      "maxItems": 6,
      "statValueMaxChars": 25,
      "statLabelMaxChars": 60
    }
  },
  "defaultData": {
