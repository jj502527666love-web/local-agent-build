{
  "id": "neogen-bullet-icons-only-slide",
  "name": "图标要点网格配图",
  "category": "neo-general",
  "description": "左侧大标题加 2-3 项带描述的图标要点卡片，右侧配图。",
  "schema": {
    "title": { "type": "text", "label": "主标题", "required": true, "maxChars": 40 },
