    { "kind": "list", "field": "bullets", "pos": { "x": 80, "y": 230, "w": 480 }, "itemSize": 16 },
    { "kind": "image", "field": "chartImage1", "pos": { "x": 620, "y": 230, "w": 580, "h": 190 } },
    { "kind": "image", "field": "chartImage2", "pos": { "x": 620, "y": 440, "w": 580, "h": 190 } }
