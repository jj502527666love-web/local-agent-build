{
  "id": "neogen-metrics-with-image-slide",
  "name": "配图加标题与指标",
  "category": "neo-general",
  "description": "左侧大幅配图，右侧标题、描述与 1-3 项指标网格。",
  "schema": {
    "title": { "type": "text", "label": "主标题", "required": true, "maxChars": 40 },
    "description": { "type": "multiline", "label": "描述正文", "maxChars": 150 },
    "image": { "type": "image", "label": "配图" },
    "metrics": { "type": "stat-list", "label": "指标(数值/标签)", "required": true, "maxItems": 3, "statValueMaxChars": 20, "statLabelMaxChars": 100 }
  },
  "defaultData": {
    "title": "竞争优势",
    "description": "我们以为客户量身定制的数字解决方案脱颖而出，并提供长期支持，确保关系持久并持续适应变化。",
    "image": "",
    "metrics": [
      { "value": "200+", "label": "满意客户" },
      { "value": "95%", "label": "客户留存率" }
    ]
  },
  "blocks": [
    { "kind": "image", "field": "image", "pos": { "x": 80, "y": 130, "w": 520, "h": 460 } },
    { "kind": "heading", "field": "title", "level": 1, "pos": { "x": 660, "y": 150, "w": 540 }, "size": 40 },
    { "kind": "paragraph", "field": "description", "pos": { "x": 660, "y": 230, "w": 540 }, "size": 18 },
    { "kind": "statGrid", "field": "metrics", "pos": { "x": 660, "y": 400, "w": 540, "h": 180 }, "valueSize": 40, "labelSize": 15, "cols": 2 }
  ]
}
