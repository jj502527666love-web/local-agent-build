    "items": [
      { "value": "趋势识别", "label": "捕捉关键指标的变化方向与拐点。" },
      { "value": "结构拆解", "label": "按维度拆分数据，定位差异来源。" },
      { "value": "异常监测", "label": "标记偏离基线的波动并及时预警。" },
      { "value": "对比分析", "label": "横向与纵向对比，验证假设结论。" },
      { "value": "归因解读", "label": "结合背景解释信号背后的原因。" },
      { "value": "行动建议", "label": "将分析结论转化为可执行动作。" }
    ]
  },
  "blocks": [
    { "kind": "heading", "field": "title", "level": 1, "pos": { "x": 80, "y": 64, "w": 1120 }, "size": 72 },
    { "kind": "bulletCards", "field": "items", "pos": { "x": 80, "y": 220, "w": 1120, "h": 400 }, "titleSize": 22, "descSize": 16, "cols": 2 }
  ]
