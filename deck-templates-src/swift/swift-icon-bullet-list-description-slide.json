    { "kind": "bulletCards", "field": "features", "pos": { "x": 80, "y": 280, "w": 1120, "h": 320 }, "titleSize": 19, "descSize": 14, "cols": 4 },
    { "kind": "rule", "pos": { "x": 80, "y": 650, "w": 1120, "h": 2 } },
    { "kind": "paragraph", "field": "website", "pos": { "x": 80, "y": 628, "w": 600 }, "size": 14, "color": "muted" }
  ]
