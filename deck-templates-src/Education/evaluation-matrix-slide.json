{
  "id": "evaluation-matrix-slide",
  "name": "评估矩阵",
  "category": "Education",
  "description": "标题与副标题，配合按评估标准与等级组织的评估矩阵卡片。",
  "schema": {
    "title": { "type": "text", "label": "标题", "required": true, "maxChars": 32 },
